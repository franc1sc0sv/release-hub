{
  "name": "@release-hub/api",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "nest start --watch --exec tsx",
    "prebuild": "pnpm --filter @release-hub/db build",
    "build": "nest build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/main",
    "logs:tail": "tail -f logs/app.jsonl",
    "logs:errors": "grep -F '\"level\":\"error\"' logs/app.jsonl | tail -n 50",
    "logs:clear": "rm -f logs/app.jsonl"
  },
  "dependencies": {
    "@apollo/server": "^4.0.0",
    "@casl/ability": "^6.0.0",
    "@nestjs/apollo": "^12.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/cqrs": "^10.0.0",
    "@nestjs/event-emitter": "^2.0.0",
    "@nestjs/graphql": "^12.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@release-hub/db": "workspace:*",
    "@release-hub/shared": "workspace:*",
    "@types/pdfkit": "^0.17.6",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.0.0",
    "express": "^5.0.0",
    "graphql": "^16.0.0",
    "graphql-ws": "^6.0.8",
    "kysely": "^0.27.0",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "pdfkit": "^0.19.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.21",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
