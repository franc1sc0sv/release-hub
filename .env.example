# Release Hub — environment variables (names only; never commit real secret values)
# Copy to .env and fill in. .env and .env.* are gitignored; only this template is tracked.

# ---------------------------------------------------------------------------
# Database (packages/db, apps/api) — Postgres connection string used by Prisma + Kysely
# Dev Postgres runs on host port 5433 (docker compose).
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/release_hub?schema=public"

# ---------------------------------------------------------------------------
# API runtime (apps/api)
# ---------------------------------------------------------------------------
# Selects the AI provider binding (see "AI provider" below):
#   "development" -> DevAiProvider (local `claude` CLI); anything else -> AnthropicAiProvider.
NODE_ENV="development"
PORT="3001"
# Allowed CORS origin for the GraphQL API (the web app).
CORS_ORIGIN="http://localhost:5173"
# Base URL of the web app, used to build invitation links in emails.
WEB_APP_URL="http://localhost:5173"

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
# Secret used to sign and verify JWTs. Set a long random value in real environments.
JWT_SECRET=""

# ---------------------------------------------------------------------------
# One-time-password email login
# ---------------------------------------------------------------------------
OTP_CODE_TTL_MINUTES="10"
OTP_MAX_ATTEMPTS="5"
OTP_MAX_CODES_PER_HOUR="5"
OTP_RESEND_COOLDOWN_SECONDS="60"

# ---------------------------------------------------------------------------
# Email / SMTP (Mailpit in dev)
# Mailpit listens on SMTP port 1025; its web UI is on 8025.
# ---------------------------------------------------------------------------
SMTP_HOST="localhost"
SMTP_PORT="1026"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Release Hub <no-reply@release-hub.local>"

# ---------------------------------------------------------------------------
# Collaboration
# ---------------------------------------------------------------------------
# Days a project invitation stays valid before it expires.
INVITATION_TTL_DAYS="7"

# ---------------------------------------------------------------------------
# GitHub App (release / PR detection) — apps/api/src/modules/integration/github.client.ts
# GitHub App ID and the App's PEM private key. Paste the full PEM (newlines as \n) for
# GITHUB_APP_PRIVATE_KEY, or point your loader at a file — keep the real key out of git.
# ---------------------------------------------------------------------------
GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY=""

# ---------------------------------------------------------------------------
# AI provider (apps/api/src/modules/ai)
# Provider is chosen by NODE_ENV above:
#   - development -> DevAiProvider: shells out to the local `claude` CLI (no API key needed).
#   - non-development -> AnthropicAiProvider: uses the @anthropic-ai/sdk, which reads
#     ANTHROPIC_API_KEY. Required only when NODE_ENV is not "development".
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=""

# ---------------------------------------------------------------------------
# Per-project integration credentials — NOT read from the environment.
# Flagsmith and Linear credentials are stored per project in the database
# (connection settings) and passed to their clients at call time, not via env:
#   - Flagsmith: instance/admin API base URL, organisation/admin API token, and the
#     per-environment key (X-Environment-Key) used for feature-state reads.
#   - Linear: per-project Linear API key used to confirm issues via the Linear GraphQL API.
# Configure these in the app's project connection settings, not here. Listed for
# discoverability only — leaving them in .env has no effect.
#
# FLAGSMITH_BASE_URL=
# FLAGSMITH_ADMIN_API_TOKEN=
# FLAGSMITH_ENVIRONMENT_KEY=
# LINEAR_API_KEY=

# ---------------------------------------------------------------------------
# Frontend (apps/web) — Vite. Only VITE_-prefixed vars are exposed to the browser.
# ---------------------------------------------------------------------------
VITE_API_URL="http://localhost:3001/graphql"
VITE_WS_URL="ws://localhost:3001/graphql"
