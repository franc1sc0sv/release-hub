{
  "name": "release-hub",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:log": "mkdir -p logs && FORCE_COLOR=0 turbo dev 2>&1 | tee logs/dev.log",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:seed": "turbo db:seed"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [],
      "allowedVersions": {
        "react": "19",
        "@types/react": "19"
      }
    },
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "@nestjs/core",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
